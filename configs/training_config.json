{
  "model": "Qwen/Qwen3-14B",
  "precision": "bfloat16",
  "method": "LoRA fine-tuning, one adapter per subreddit plus a single pooled adapter",
  "prompt_template": "enriched_v2",
  "lora": {
    "rank": 16,
    "alpha": 16,
    "dropout": 0.05,
    "target_modules": ["q_proj", "k_proj", "v_proj", "o_proj", "gate_proj", "up_proj", "down_proj"]
  },
  "training": {
    "epochs": 2,
    "completion_only_loss": true,
    "learning_rate": 2e-4,
    "lr_scheduler": "cosine",
    "warmup_steps": 50,
    "batch_size": 1,
    "gradient_accumulation": 8,
    "seed": 42
  },
  "evaluation": {
    "engine": "vLLM with LoRA adapters",
    "temperature": 0.1,
    "top_p": 0.95
  },
  "adapter_naming": "r4_stacked_<subreddit>",
  "notes": "Configuration fixed after a sequence of tuning rounds on three subreddits (relationships, changemyview, politics) before the full 15-subreddit run."
}
